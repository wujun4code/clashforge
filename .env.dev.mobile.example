# Copy this file to .env.dev.mobile and fill in your values.
# .env.dev.mobile is gitignored — never commit it.
#
# Used by scripts/build_android.ps1 to embed the free-node subscription
# URL (AES-encrypted) into the APK at build time.

FREE_NODE_URL=https://example.com/sub?token=REPLACE_ME
FREE_NODE_AES_KEY=REPLACE_ME_32CHAR_KEY
