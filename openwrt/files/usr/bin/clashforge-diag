#!/bin/sh
# clashforge-diag — ClashForge 现场诊断采集脚本
# 用法: clashforge-diag
# 输出保存至 /tmp/cf-diag.txt，网络恢复后把内容发给支持方分析

set -u
OUT="/tmp/cf-diag.txt"
API="http://127.0.0.1:7777/api/v1"
SEP="════════════════════════════════════════"

log() { printf "\n%s\n%s\n" "$SEP" "$*"; }
run() { printf "\n▶ %s\n" "$*"; eval "$*" 2>&1 || true; }

{
log "【0】采集时间 / 基本信息"
date
uname -a
cat /etc/openwrt_release 2>/dev/null || true

# ─────────────────────────────────────────────────────────
log "【1】进程状态"
run "ps w 2>/dev/null | grep -E 'mihomo|clashforge|dnsmasq|PID' | grep -v grep"

MIHOMO_PID=$(ps 2>/dev/null | grep mihomo | grep -v grep | awk '{print $1}' | head -1)
if [ -n "$MIHOMO_PID" ]; then
    echo "mihomo PID: $MIHOMO_PID"
    cat /proc/"$MIHOMO_PID"/status 2>/dev/null || true
    printf "cmdline: "; cat /proc/"$MIHOMO_PID"/cmdline 2>/dev/null | tr '\0' ' '; echo ""
    cat /proc/"$MIHOMO_PID"/stat 2>/dev/null | awk '{print "starttime(ticks):", $22}'
else
    echo "⚠ mihomo 进程未找到"
fi

# ─────────────────────────────────────────────────────────
log "【2】端口绑定 — /proc/net/tcp (LISTEN=0A)"
echo "常用端口十六进制: 7777=1E61  7874=1EC2  7893=1EE5  53=0035"
awk 'NR>1 && $4=="0A" {print}' /proc/net/tcp  2>/dev/null | head -40
awk 'NR>1 && $4=="0A" {print}' /proc/net/tcp6 2>/dev/null | head -40

log "【2b】端口绑定 — /proc/net/udp (所有绑定)"
awk 'NR>1 {print}' /proc/net/udp  2>/dev/null | head -40
awk 'NR>1 {print}' /proc/net/udp6 2>/dev/null | head -40

log "【2c】ss / netstat 快照"
ss -tlnpu 2>/dev/null || netstat -tlnpu 2>/dev/null || echo "ss/netstat 不可用"

# ─────────────────────────────────────────────────────────
log "【3】ClashForge API — 服务状态 (127.0.0.1:7777)"
run "curl -sf --max-time 5 '$API/status'"
echo ""

log "【3b】ClashForge API — 运行配置端口"
run "curl -sf --max-time 5 '$API/config'"
echo ""

log "【3c】ClashForge API — 端口逐项检测 (/setup/port-check)"
run "curl -sf --max-time 10 '$API/setup/port-check'"
echo ""

log "【3d】ClashForge API — 核心版本"
run "curl -sf --max-time 5 '$API/core/version'"
echo ""

# ─────────────────────────────────────────────────────────
log "【4】ClashForge 配置文件 (config.toml)"
for p in /etc/metaclash/config.toml /etc/clashforge/config.toml; do
    if [ -f "$p" ]; then
        echo "=== $p ==="
        cat "$p"
        echo ""
    fi
done

# ─────────────────────────────────────────────────────────
log "【5】Mihomo 生成配置 (config.yaml)"
for p in /etc/metaclash/config.yaml \
         /etc/clashforge/config.yaml \
         /tmp/metaclash/config.yaml \
         /var/run/metaclash/config.yaml; do
    if [ -f "$p" ]; then
        echo "=== $p ==="
        cat "$p"
        echo ""
    fi
done
echo "--- via API ---"
run "curl -sf --max-time 5 '$API/config/mihomo'"
echo ""

# ─────────────────────────────────────────────────────────
log "【6】DNS 状态"
run "cat /etc/resolv.conf"

echo "--- dnsmasq 主配 (非注释行) ---"
grep -vE "^#|^$" /etc/dnsmasq.conf 2>/dev/null || true

echo "--- dnsmasq.d/ ---"
ls -la /etc/dnsmasq.d/ 2>/dev/null || echo "目录不存在"
for f in /etc/dnsmasq.d/*; do
    [ -f "$f" ] && echo "=== $f ===" && cat "$f" && echo "" || true
done

echo "--- nslookup google.com (系统 DNS 链路) ---"
nslookup google.com 2>&1 || true

echo "--- nslookup google.com 直连 127.0.0.1 (mihomo DNS) ---"
nslookup google.com 127.0.0.1 2>&1 || true

# ─────────────────────────────────────────────────────────
log "【7】nftables 规则"
run "nft list ruleset"
run "nft list table inet metaclash 2>&1"

# ─────────────────────────────────────────────────────────
log "【8】IP 策略路由"
run "ip rule list"
run "ip route show table 100 2>/dev/null || ip route show table all | grep 'table 100'"
run "ip route show"

# ─────────────────────────────────────────────────────────
log "【9】网络接口"
run "ip addr show"
run "ip link show"

# ─────────────────────────────────────────────────────────
log "【10】系统资源"
run "free"
run "df -h"
run "uptime"

# ─────────────────────────────────────────────────────────
log "【11】OpenWrt 服务注册"
ls -la /etc/init.d/ 2>/dev/null | grep -iE "clash|mihomo|metaclash" || echo "无相关 init.d 条目"
for svc in clashforge metaclash mihomo; do
    if [ -f "/etc/init.d/$svc" ]; then
        echo "=== /etc/init.d/$svc ==="
        /etc/init.d/"$svc" enabled 2>/dev/null && echo "enabled" || echo "disabled/unknown"
    fi
done

# ─────────────────────────────────────────────────────────
log "【12】系统日志 (最近 150 行)"
logread 2>/dev/null | tail -150 || \
    cat /var/log/messages 2>/dev/null | tail -150 || \
    dmesg | tail -50 || \
    echo "无法获取系统日志"

# ─────────────────────────────────────────────────────────
log "【13】ClashForge 独立日志文件"
for p in /var/log/clashforge.log /var/log/metaclash.log \
         /tmp/clashforge.log /tmp/metaclash.log; do
    if [ -f "$p" ]; then
        echo "=== $p (最后 100 行) ==="
        tail -100 "$p"
        echo ""
    fi
done

# ─────────────────────────────────────────────────────────
log "【14】Mihomo 可执行文件 & 版本"
for p in /usr/bin/mihomo /usr/bin/mihomo-clashforge \
         /usr/local/bin/mihomo /opt/mihomo/mihomo; do
    if [ -f "$p" ]; then
        echo "=== $p ==="
        ls -lh "$p"
        "$p" -v 2>&1 | head -3 || true
    fi
done

# ─────────────────────────────────────────────────────────
log "【15】ClashForge 可执行文件 & 版本"
for p in /usr/bin/clashforge /usr/local/bin/clashforge; do
    if [ -f "$p" ]; then
        echo "=== $p ==="
        ls -lh "$p"
        "$p" version 2>&1 | head -3 || true
    fi
done

# ─────────────────────────────────────────────────────────
log "【16】/etc/metaclash 目录结构"
find /etc/metaclash /etc/clashforge 2>/dev/null -maxdepth 4 | head -60 || true
ls -laR /etc/metaclash 2>/dev/null | head -80 || true

# ─────────────────────────────────────────────────────────
log "【17】连通性探测"
echo "--- 直连 ipify (不走代理) ---"
curl -sf --max-time 8 https://api.ipify.org 2>&1 || echo "失败"
echo ""

echo "--- 经 mixed 端口代理 (127.0.0.1:7893) ---"
curl -sf --max-time 8 --proxy http://127.0.0.1:7893 https://api.ipify.org 2>&1 || echo "失败"
echo ""

echo "--- TCP connect 各端口 ---"
for PORT in 7777 7874 7893 53; do
    result=$(curl --connect-timeout 1 --max-time 2 -o /dev/null \
        -w "HTTP %{http_code}" "http://127.0.0.1:$PORT" 2>&1 || echo "refused/timeout")
    echo "  :$PORT → $result"
done

# ─────────────────────────────────────────────────────────
log "【18】OOM / Crash 记录"
dmesg 2>/dev/null | grep -iE "kill|oom|segfault|mihomo|clashforge" | tail -20 || true
cat /proc/last_kmsg 2>/dev/null | grep -iE "kill|oom|segfault" | tail -10 || true

# ─────────────────────────────────────────────────────────
log "【19】ESTABLISHED TCP 连接数 (mihomo 活跃连接)"
awk 'NR>1 && $4=="01" {count++} END {print "ESTABLISHED:", count+0}' \
    /proc/net/tcp 2>/dev/null || true

# ─────────────────────────────────────────────────────────
log "【20】采集完成"
date
echo "文件: $OUT"

} 2>&1 | tee "$OUT"

echo ""
echo "✅ 诊断完成 → $OUT"
echo "   网络恢复后: scp root@<router-ip>:$OUT ./"
