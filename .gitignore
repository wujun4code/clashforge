# Binary and build outputs
bin/
/clashforge

# Android native libs — downloaded by mobile/scripts/download-mihomo.sh
mobile/android/app/src/main/jniLibs/

# Local build secrets — contains subscription URLs and encryption keys
.env.dev.mobile
# Local bundled-subscriptions config (copy from mobile/.bundled_subs.json.example)
mobile/.bundled_subs.json

# Private test data - NEVER commit these
testdata/sample-clash-config.yaml
testdata/*.yaml
testdata/*.toml
testdata/private/

# Go toolchain
*.test
*.prof
coverage.out
internal/api/ui_dist/

# Local packaging artifacts
*.ipk
/data.tar.gz
/control.tar.gz
/debian-binary
/ipk/
/control
/control.extracted
/dist/
__pycache__/
internal/api/ui_dist/

# Temporary debug files (logcat, UI dumps, adb captures)
tmp-*

# Diagnostic log runs generated by clashforgectl diag
scripts/diag-logs/

# Geodata binaries — downloaded at CI build time
mobile/assets/geodata/country.mmdb
mobile/assets/geodata/geosite.dat

# Claude Code runtime files
.claude/scheduled_tasks.lock
