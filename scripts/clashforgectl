#!/usr/bin/env bash
# clashforgectl — ClashForge Remote Control Script (macOS / Linux)
#
# Uploads clashforgectl.sh to the target router and executes the requested
# subcommand over SSH, providing a unified control surface from a POSIX host.
#
# Usage:
#   ./scripts/clashforgectl --router 192.168.1.1 status
#   ./scripts/clashforgectl --router 192.168.1.1 stop
#   ./scripts/clashforgectl --router 192.168.1.1 reset
#   ./scripts/clashforgectl --router 192.168.1.1 reset --start
#   ./scripts/clashforgectl --router 192.168.1.1 upgrade
#   ./scripts/clashforgectl --router 192.168.1.1 upgrade --version v0.1.0-beta.1
#   ./scripts/clashforgectl --router 192.168.1.1 upgrade --mirror https://ghproxy.com
#   ./scripts/clashforgectl --router 192.168.1.1 upgrade --base-url https://releases.example.com
#   ./scripts/clashforgectl --router 192.168.1.1 upgrade --purge
#   ./scripts/clashforgectl --router 192.168.1.1 upgrade --remote-download   # legacy: let router download
#   ./scripts/clashforgectl --router 192.168.1.1 deploy
#   ./scripts/clashforgectl --router 192.168.1.1 deploy --skip ui
#   ./scripts/clashforgectl --router 192.168.1.1 deploy --skip go
#   ./scripts/clashforgectl --router 192.168.1.1 deploy --purge
#   ./scripts/clashforgectl --router 192.168.1.1 compat
#   ./scripts/clashforgectl --router 192.168.1.1 uninstall
#   ./scripts/clashforgectl --router 192.168.1.1 uninstall --keep-config
#   ./scripts/clashforgectl --router 192.168.1.1 diag
#   ./scripts/clashforgectl --router 192.168.1.1 diag --fetch
#   ./scripts/clashforgectl --router 192.168.1.1 diag --fetch --local-path ./cf-diag.txt --redact
#   ./scripts/clashforgectl --router 192.168.1.1 openclash
#   ./scripts/clashforgectl --router 192.168.1.1 openclash --kill
#   ./scripts/clashforgectl --router 192.168.20.1 netdiag
#   ./scripts/clashforgectl --router 192.168.20.1 netdiag --monitor
#   ./scripts/clashforgectl --router 192.168.20.1 netdiag --api-port 7777 --log-dir ./diag-logs
#
# Requirements:
#   - ssh and scp must be available (standard OpenSSH)
#   - clashforgectl.sh must exist alongside this script (or in scripts/)
#   - Password-less SSH key auth is recommended

set -euo pipefail

# ── helpers ───────────────────────────────────────────────────────────────────
CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'

log()  { printf "${CYAN}[clashforgectl]${NC} %s\n"       "$*"; }
ok()   { printf "${GREEN}[clashforgectl] OK  %s${NC}\n"  "$*"; }
warn() { printf "${YELLOW}[clashforgectl] WARN %s${NC}\n" "$*"; }
die()  { printf "${RED}[clashforgectl] ERROR %s${NC}\n"  "$*" >&2; exit 1; }

sh_quote() {
    # POSIX single-quote escaping: replace ' with '\''
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

download_with_fallback() {
    local name="$1" dest="$2"; shift 2
    local url
    for url in "$@"; do
        log "Downloading $name from $url"
        rm -f "$dest"
        if command -v curl >/dev/null 2>&1; then
            curl -fsSL --connect-timeout 15 --max-time 300 -o "$dest" "$url" 2>/dev/null || true
        elif command -v wget >/dev/null 2>&1; then
            wget --timeout=300 -qO "$dest" "$url" 2>/dev/null || true
        else
            warn "Neither curl nor wget is available locally"
            return 1
        fi
        if [ -s "$dest" ]; then
            ok "$name downloaded ($(wc -c < "$dest" | tr -d ' ') bytes)"
            return 0
        fi
        warn "$name download failed: $url"
    done
    return 1
}

# ══════════════════════════════════════════════════════════════════════════════
# NETDIAG — client-side network diagnostics.
#
# This is the POSIX counterpart to scripts/diagnose-net.ps1 and the netdiag
# action in clashforgectl.ps1. It runs from the client machine, talks directly
# to the ClashForge HTTP API on the router, and saves a paired diagnostic run
# under --log-dir.
# ══════════════════════════════════════════════════════════════════════════════

ND_RUN_DIR=""
ND_LOG_FILE=""

nd_ts() { date '+%H:%M:%S'; }

nd_write() {
    local msg="$1"
    local line="[$(nd_ts)] $msg"
    printf '%s\n' "$line"
    [ -n "${ND_LOG_FILE:-}" ] && printf '%s\n' "$line" >> "$ND_LOG_FILE"
}

nd_section() {
    nd_write "── $1 ─────────────────────────────────────────────────────────"
}

nd_have_http_client() {
    command -v curl >/dev/null 2>&1 || command -v wget >/dev/null 2>&1
}

nd_http_body() {
    local url="$1" timeout="${2:-8}"
    if command -v curl >/dev/null 2>&1; then
        curl -L -sS --max-time "$timeout" "$url" 2>/dev/null || true
    else
        wget -qO- -T "$timeout" "$url" 2>/dev/null || true
    fi
}

nd_http_status() {
    local url="$1" timeout="${2:-8}"
    local out code total ms start end
    if command -v curl >/dev/null 2>&1; then
        out="$(curl -L -sS --max-time "$timeout" -o /dev/null -w '%{http_code} %{time_total}' "$url" 2>/dev/null || true)"
        code="${out%% *}"
        total="${out#* }"
        if [ -n "$total" ] && [ "$total" != "$out" ]; then
            ms="$(awk -v t="$total" 'BEGIN { printf "%d", t * 1000 }' 2>/dev/null || printf '0')"
        else
            ms="0"
        fi
    else
        start="$(date +%s)"
        code="$(wget -qO /dev/null -T "$timeout" --server-response "$url" 2>&1 | awk '/HTTP\//{c=$2} END{print c}')"
        end="$(date +%s)"
        ms="$(( (end - start) * 1000 ))"
    fi
    [ -n "$code" ] || code="000"
    printf '%s %s\n' "$code" "$ms"
}

nd_status_ok() {
    case "$1" in
        2*|3*|4*) return 0 ;;
        *) return 1 ;;
    esac
}

nd_api_get() {
    nd_http_body "http://${ROUTER}:${NETDIAG_API_PORT}$1" "${2:-8}"
}

nd_api_post() {
    local path="$1"
    local body="${2:-}"
    if command -v curl >/dev/null 2>&1; then
        if [ -n "$body" ]; then
            curl -sS --max-time 20 -X POST \
                -H 'Content-Type: application/json' \
                -d "$body" \
                "http://${ROUTER}:${NETDIAG_API_PORT}${path}" 2>/dev/null || true
        else
            curl -sS --max-time 20 -X POST "http://${ROUTER}:${NETDIAG_API_PORT}${path}" 2>/dev/null || true
        fi
    else
        if [ -n "$body" ]; then
            wget -qO- -T 20 --method=POST \
                --header='Content-Type: application/json' \
                --body-data="$body" \
                "http://${ROUTER}:${NETDIAG_API_PORT}${path}" 2>/dev/null || true
        else
            wget -qO- -T 20 --method=POST "http://${ROUTER}:${NETDIAG_API_PORT}${path}" 2>/dev/null || true
        fi
    fi
}

nd_api_delete() {
    local path="$1"
    if command -v curl >/dev/null 2>&1; then
        curl -sS --max-time 15 -X DELETE "http://${ROUTER}:${NETDIAG_API_PORT}${path}" 2>/dev/null || true
    else
        wget -qO- -T 15 --method=DELETE "http://${ROUTER}:${NETDIAG_API_PORT}${path}" 2>/dev/null || true
    fi
}

nd_jq() {
    local json="$1" filter="$2"
    command -v jq >/dev/null 2>&1 || return 0
    printf '%s' "$json" | jq -r "$filter // empty" 2>/dev/null || true
}

nd_json_str() {
    local json="$1" key="$2"
    local val
    val="$(nd_jq "$json" ".. | objects | .$key? | strings" | head -1 || true)"
    if [ -n "$val" ]; then
        printf '%s\n' "$val"
    else
        printf '%s' "$json" | tr '\n' ' ' | sed -n "s/.*\"$key\"[[:space:]]*:[[:space:]]*\"\([^\"]*\)\".*/\1/p" | head -1
    fi
}

nd_ping() {
    local target="$1"
    if [ "$(uname -s 2>/dev/null || printf unknown)" = "Darwin" ]; then
        ping -c 1 -W 2000 "$target" >/dev/null 2>&1
    else
        ping -c 1 -W 2 "$target" >/dev/null 2>&1
    fi
}

nd_dns_resolve() {
    local domain="$1" server="${2:-}" ip=""
    if command -v dig >/dev/null 2>&1; then
        if [ -n "$server" ]; then
            ip="$(dig +time=2 +tries=1 +short @"$server" "$domain" A 2>/dev/null | grep -E '^[0-9.]+$' | head -1 || true)"
        else
            ip="$(dig +time=2 +tries=1 +short "$domain" A 2>/dev/null | grep -E '^[0-9.]+$' | head -1 || true)"
        fi
    elif command -v nslookup >/dev/null 2>&1; then
        if [ -n "$server" ]; then
            ip="$(nslookup "$domain" "$server" 2>/dev/null | awk '/^Address: /{a=$2} END{print a}' | grep -E '^[0-9.]+$' | head -1 || true)"
        else
            ip="$(nslookup "$domain" 2>/dev/null | awk '/^Address: /{a=$2} END{print a}' | grep -E '^[0-9.]+$' | head -1 || true)"
        fi
    elif command -v host >/dev/null 2>&1; then
        ip="$(host "$domain" 2>/dev/null | awk '/has address/{print $4; exit}' || true)"
    elif command -v getent >/dev/null 2>&1; then
        ip="$(getent ahostsv4 "$domain" 2>/dev/null | awk '{print $1; exit}' || true)"
    fi
    printf '%s\n' "$ip"
}

nd_extract_provider_ip() {
    local body="$1"
    local ip
    ip="$(nd_json_str "$body" remote_addr)"
    [ -n "$ip" ] || ip="$(nd_json_str "$body" ip)"
    [ -n "$ip" ] || ip="$(nd_json_str "$body" query)"
    printf '%s\n' "$ip"
}

nd_extract_provider_loc() {
    local body="$1"
    local loc city region country org isp addr
    addr="$(nd_json_str "$body" addr)"
    [ -n "$addr" ] && { printf '%s\n' "$addr"; return; }
    city="$(nd_json_str "$body" city)"
    region="$(nd_json_str "$body" region)"
    country="$(nd_json_str "$body" country_name)"
    [ -n "$country" ] || country="$(nd_json_str "$body" country)"
    org="$(nd_json_str "$body" org)"
    isp="$(nd_json_str "$body" isp)"
    loc="$(printf '%s %s %s %s %s' "$city" "$region" "$country" "$isp" "$org" | awk '{$1=$1; print}')"
    printf '%s\n' "$loc"
}

nd_fetch_ip_provider() {
    local name="$1" url="$2" gbk="${3:-0}" tmp body ip loc
    tmp="$(mktemp "${TMPDIR:-/tmp}/clashforge-ip.XXXXXX")" || return 1
    if command -v curl >/dev/null 2>&1; then
        curl -L -sS --max-time 8 -o "$tmp" "$url" 2>/dev/null || true
    else
        wget -qO "$tmp" -T 8 "$url" 2>/dev/null || true
    fi
    if [ "$gbk" -eq 1 ] && command -v iconv >/dev/null 2>&1; then
        body="$(iconv -f GB18030 -t UTF-8 "$tmp" 2>/dev/null || cat "$tmp")"
    else
        body="$(cat "$tmp" 2>/dev/null || true)"
    fi
    rm -f "$tmp"
    ip="$(nd_extract_provider_ip "$body")"
    loc="$(nd_extract_provider_loc "$body")"
    if [ -n "$ip" ]; then
        printf '%s\t%s\t%s\n' "$name" "$ip" "${loc:-}"
        return 0
    fi
    printf '%s\t-\t请求失败或无法解析\n' "$name"
    return 1
}

nd_clear_router_logs() {
    nd_api_delete /api/v1/service-log >/dev/null
    nd_api_delete /api/v1/logs >/dev/null
}

nd_prescan_router_logs() {
    local svc req svc_count req_count reply
    nd_section "路由器现存日志扫描"
    svc="$(nd_api_get '/api/v1/service-log?lines=5000' 15)"
    req="$(nd_api_get '/api/v1/logs?limit=5000' 15)"
    svc_count="$(printf '%s' "$svc" | awk '{ n += gsub(/"time"/, "&") } END { print n + 0 }')"
    req_count="$(printf '%s' "$req" | awk '{ n += gsub(/"ts"/, "&") } END { print n + 0 }')"
    nd_write "当前服务日志条目(近似): ${svc_count:-0}"
    nd_write "当前请求日志条目: ${req_count:-0}"
    if [ "${svc_count:-0}" = "0" ] && [ "${req_count:-0}" = "0" ]; then
        nd_write "无历史日志，无需清理"
        return 0
    fi
    if [ "$YES" -eq 1 ]; then
        reply="y"
    else
        printf '[clashforgectl] 检测到历史日志，可能干扰本轮诊断归因。清理后再开始？[y/N] '
        read -r reply
    fi
    case "$reply" in
        y|Y|yes|YES) nd_clear_router_logs; nd_write "已清理路由器日志缓冲" ;;
        *) nd_write "保留现有日志，继续..." ;;
    esac
}

nd_mihomo_ok_from_health() {
    local hc="$1" ok
    ok="$(nd_jq "$hc" '.data.process.mihomo.ok // .data.mihomo.ok // .process.mihomo.ok // false' | head -1 || true)"
    if [ "$ok" = "true" ]; then
        return 0
    fi
    printf '%s' "$hc" | tr '\n' ' ' | grep -q '"mihomo".*"ok"[[:space:]]*:[[:space:]]*true'
}

nd_show_router_status() {
    local hc="$1" snap="${2:-}" cf_state cf_ok cf_uptime mh_state mh_ok dns_active dns_mode tp_active tp_mode net_mode dns_cfg sub_label
    cf_state="$(nd_jq "$hc" '.data.process.clashforge.state // .data.clashforge.state // .process.clashforge.state // "?"' | head -1)"
    cf_ok="$(nd_jq "$hc" '.data.process.clashforge.ok // .data.clashforge.ok // .process.clashforge.ok // "?"' | head -1)"
    cf_uptime="$(nd_jq "$hc" '.data.process.clashforge.uptime // .data.clashforge.uptime // .process.clashforge.uptime // "?"' | head -1)"
    mh_state="$(nd_jq "$hc" '.data.process.mihomo.state // .data.mihomo.state // .process.mihomo.state // "?"' | head -1)"
    mh_ok="$(nd_jq "$hc" '.data.process.mihomo.ok // .data.mihomo.ok // .process.mihomo.ok // "?"' | head -1)"
    dns_active="$(nd_jq "$hc" '.data.dns.active // .dns.active // "?"' | head -1)"
    dns_mode="$(nd_jq "$hc" '.data.dns.dnsmasq_mode // .dns.dnsmasq_mode // "?"' | head -1)"
    tp_active="$(nd_jq "$hc" '.data.transparent_proxy.active // .transparent_proxy.active // "?"' | head -1)"
    tp_mode="$(nd_jq "$hc" '.data.transparent_proxy.mode // .transparent_proxy.mode // "?"' | head -1)"
    nd_write "  ClashForge : state=${cf_state:-?}  ok=${cf_ok:-?}  uptime=${cf_uptime:-?}s"
    nd_write "  mihomo     : state=${mh_state:-?}  ok=${mh_ok:-?}"
    nd_write "  dns        : active=${dns_active:-?}  mode=${dns_mode:-?}"
    nd_write "  tproxy     : active=${tp_active:-?}  mode=${tp_mode:-?}"
    if [ -n "$snap" ]; then
        net_mode="$(nd_jq "$snap" '.data.network.mode // .network.mode // "?"' | head -1)"
        dns_cfg="$(nd_jq "$snap" '.data.dns.mode // .dns.mode // "?"' | head -1)"
        sub_label="$(nd_jq "$snap" '.data.active_source.sub_name // .active_source.sub_name // .data.active_source.filename // .active_source.filename // empty' | head -1)"
        nd_write "  配置       : 网络=${net_mode:-?}  DNS=${dns_cfg:-?}  来源=${sub_label:-(未配置)}"
    fi
    nd_mihomo_ok_from_health "$hc"
}

nd_config_snapshot() {
    local cfg as subs mc yaml_file yaml line_count mode dns_mode dns_strategy active_type sub_name sub_id filename subs_count
    nd_section "配置快照"
    cfg="$(nd_api_get /api/v1/config 15)"
    as="$(nd_api_get /api/v1/config/active-source 15)"
    subs="$(nd_api_get /api/v1/subscriptions 15)"
    mc="$(nd_api_get /api/v1/config/mihomo 20)"
    [ -n "$cfg" ] && { if command -v jq >/dev/null 2>&1; then printf '%s' "$cfg" | jq '.data // .' > "$ND_RUN_DIR/cf_config.json" 2>/dev/null || printf '%s\n' "$cfg" > "$ND_RUN_DIR/cf_config.json"; else printf '%s\n' "$cfg" > "$ND_RUN_DIR/cf_config.json"; fi; }
    [ -n "$as" ] && { if command -v jq >/dev/null 2>&1; then printf '%s' "$as" | jq '.data // .' > "$ND_RUN_DIR/active_source.json" 2>/dev/null || printf '%s\n' "$as" > "$ND_RUN_DIR/active_source.json"; else printf '%s\n' "$as" > "$ND_RUN_DIR/active_source.json"; fi; }
    [ -n "$subs" ] && { if command -v jq >/dev/null 2>&1; then printf '%s' "$subs" | jq '.data // .' > "$ND_RUN_DIR/subscriptions.json" 2>/dev/null || printf '%s\n' "$subs" > "$ND_RUN_DIR/subscriptions.json"; else printf '%s\n' "$subs" > "$ND_RUN_DIR/subscriptions.json"; fi; }

    yaml_file="$ND_RUN_DIR/mihomo_config.yaml"
    if command -v jq >/dev/null 2>&1; then
        yaml="$(printf '%s' "$mc" | jq -r '.data.content // .content // empty' 2>/dev/null || true)"
    else
        yaml="$(printf '%s' "$mc" | sed -n 's/.*"content"[[:space:]]*:[[:space:]]*"\(.*\)".*/\1/p' | sed 's/\\n/\
/g; s/\\"/"/g' || true)"
    fi
    [ -n "$yaml" ] && printf '%s\n' "$yaml" > "$yaml_file"

    mode="$(nd_jq "$cfg" '.data.network.mode // .network.mode // "?"' | head -1)"
    dns_mode="$(nd_jq "$cfg" '.data.dns.mode // .dns.mode // "?"' | head -1)"
    dns_strategy="$(nd_jq "$cfg" '.data.dns.strategy // .dns.strategy // "legacy"' | head -1)"
    active_type="$(nd_jq "$as" '.data.active_source.type // .active_source.type // "?"' | head -1)"
    sub_name="$(nd_jq "$as" '.data.active_source.sub_name // .active_source.sub_name // empty' | head -1)"
    sub_id="$(nd_jq "$as" '.data.active_source.sub_id // .active_source.sub_id // empty' | head -1)"
    filename="$(nd_jq "$as" '.data.active_source.filename // .active_source.filename // empty' | head -1)"
    subs_count="$(nd_jq "$subs" '(.data.subscriptions // .subscriptions // []) | length' | head -1)"
    line_count=0
    [ -f "$yaml_file" ] && line_count="$(wc -l < "$yaml_file" | tr -d ' ')"
    nd_write "  网络模式 : ${mode:-?}"
    nd_write "  DNS 模式 : ${dns_mode:-?}  策略=${dns_strategy:-?}"
    if [ "$active_type" = "subscription" ]; then
        nd_write "  活跃来源 : 订阅: ${sub_name:-?} (id=${sub_id:-?})"
    elif [ -n "$filename" ]; then
        nd_write "  活跃来源 : 文件: $filename"
    else
        nd_write "  活跃来源 : (未配置)"
    fi
    nd_write "  订阅数量 : ${subs_count:-?}"
    nd_write "  mihomo YAML: ${line_count} 行"
}

nd_start_mihomo() {
    local i hc start_resp applied warnings
    nd_section "启动 mihomo"
    nd_write "  -> POST /api/v1/core/start"
    start_resp="$(nd_api_post /api/v1/core/start)"
    applied="$(nd_jq "$start_resp" '.data.takeover_applied // .takeover_applied // [] | join(", ")' | head -1)"
    warnings="$(nd_jq "$start_resp" '.data.takeover_warnings // .takeover_warnings // [] | join("; ")' | head -1)"
    [ -n "$applied" ] && nd_write "  自动接管: $applied"
    [ -n "$warnings" ] && nd_write "  接管警告: $warnings"
    nd_write "  等待 mihomo 就绪 (最多 40s)..."
    for i in $(seq 1 20); do
        sleep 2
        hc="$(nd_api_get /api/v1/health/check 8)"
        if nd_mihomo_ok_from_health "$hc"; then
            nd_write "  mihomo 已就绪"
            nd_ensure_transparent_takeover "core/start 后检查"
            return 0
        fi
        nd_write "  ...等待中 ($((i * 2))s)"
    done
    nd_write "  40s 超时，mihomo 未就绪"
    return 1
}

nd_ensure_transparent_takeover() {
    local reason="${1:-}" cfg hc mode apply tp_active nft_active net_block tp_block nft_block body resp msg
    cfg="$(nd_api_get /api/v1/config 10)"
    hc="$(nd_api_get /api/v1/health/check 10)"
    [ -n "$cfg" ] && [ -n "$hc" ] || return 0

    mode="$(nd_jq "$cfg" '.data.network.mode // .network.mode // "none"' | head -1)"
    apply="$(nd_jq "$cfg" '.data.network.apply_on_start // .network.apply_on_start // false' | head -1)"
    tp_active="$(nd_jq "$hc" '.data.transparent_proxy.active // .transparent_proxy.active // false' | head -1)"
    nft_active="$(nd_jq "$hc" '.data.nft.active // .nft.active // false' | head -1)"
    if [ -z "$mode" ] || [ -z "$apply" ]; then
        net_block="$(printf '%s' "$cfg" | tr '\n' ' ' | sed 's/.*"network"[[:space:]]*:[[:space:]]*{//; s/}[[:space:]]*,[[:space:]]*"dns".*//')"
        [ -n "$mode" ] || mode="$(printf '%s' "$net_block" | sed -n 's/.*"mode"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
        if [ -z "$apply" ]; then
            printf '%s' "$net_block" | grep -q '"apply_on_start"[[:space:]]*:[[:space:]]*true' && apply="true" || apply="false"
        fi
    fi
    if [ -z "$tp_active" ]; then
        tp_block="$(printf '%s' "$hc" | tr '\n' ' ' | sed 's/.*"transparent_proxy"[[:space:]]*:[[:space:]]*{//; s/}[[:space:]]*,[[:space:]]*"nft".*//')"
        printf '%s' "$tp_block" | grep -q '"active"[[:space:]]*:[[:space:]]*true' && tp_active="true" || tp_active="false"
    fi
    if [ -z "$nft_active" ]; then
        nft_block="$(printf '%s' "$hc" | tr '\n' ' ' | sed 's/.*"nft"[[:space:]]*:[[:space:]]*{//; s/}[[:space:]]*,[[:space:]]*"ports".*//')"
        printf '%s' "$nft_block" | grep -q '"active"[[:space:]]*:[[:space:]]*true' && nft_active="true" || nft_active="false"
    fi
    [ "$apply" = "true" ] || return 0
    [ -n "$mode" ] && [ "$mode" != "none" ] || return 0
    if [ "$tp_active" = "true" ] && [ "$nft_active" = "true" ]; then
        return 0
    fi

    if [ -n "$reason" ]; then
        nd_write "  -> 按配置补齐透明代理/防火墙接管 ($reason): mode=$mode"
    else
        nd_write "  -> 按配置补齐透明代理/防火墙接管: mode=$mode"
    fi
    body="{\"module\":\"transparent_proxy\",\"mode\":\"$mode\",\"stop_services\":[]}"
    resp="$(nd_api_post /api/v1/overview/takeover "$body")"
    msg="$(nd_jq "$resp" '.data.message // .message // empty' | head -1)"
    if [ -n "$resp" ]; then
        nd_write "  透明代理/防火墙已接管: ${msg:-ok}"
    else
        nd_write "  自动补齐透明代理/防火墙接管失败，请在「代理服务」页手动接管"
    fi
}

nd_probe_suite() {
    local start_ts target domain ip fake code ms row name group url gbk result hc op ok_count fail_count svc req f sz
    start_ts="$(date +%s)"
    nd_config_snapshot

    nd_section "1. Ping"
    for target in "$ROUTER" 8.8.8.8 114.114.114.114; do
        if nd_ping "$target"; then
            nd_write "  $(printf '%-16s' "$target") : OK"
        else
            nd_write "  $(printf '%-16s' "$target") : FAIL"
        fi
    done

    nd_section "2. DNS 解析"
    for row in \
        "google.com|国外-GFW" \
        "github.com|国外-GFW" \
        "openai.com|国外-GFW" \
        "taobao.com|国内直连" \
        "music.163.com|国内直连" \
        "baidu.com|国内直连"; do
        domain="${row%%|*}"
        group="${row#*|}"
        ip="$(nd_dns_resolve "$domain")"
        fake=""
        case "$ip" in 198.18.*|198.19.*) fake=" [fake-ip]" ;; esac
        if [ -n "$ip" ]; then
            nd_write "  $(printf '%-18s' "$domain") ${group}  $ip$fake"
        else
            nd_write "  $(printf '%-18s' "$domain") ${group}  FAIL"
        fi
    done
    for domain in google.com github.com; do
        ip="$(nd_dns_resolve "$domain" 8.8.8.8)"
        nd_write "  $(printf '%-18s' "$domain (8.8.8.8)") 直连外部  ${ip:-FAIL}"
    done

    nd_section "3. 访问检查"
    result="$(nd_http_status 'http://connectivitycheck.gstatic.com/generate_204' 5)"
    code="${result%% *}"; ms="${result#* }"
    if nd_status_ok "$code"; then
        nd_write "  connectivitycheck/204  OK    ${ms}ms"
    else
        nd_write "  connectivitycheck/204  FAIL  HTTP ${code}  ${ms}ms"
    fi
    for row in \
        "淘宝|国内|https://www.taobao.com" \
        "网易云音乐|国内|https://music.163.com" \
        "GitHub|国外|https://github.com" \
        "Google|国外|https://www.google.com" \
        "OpenAI|AI|https://chat.openai.com" \
        "Gemini|AI|https://gemini.google.com"; do
        name="${row%%|*}"
        row="${row#*|}"
        group="${row%%|*}"
        url="${row#*|}"
        result="$(nd_http_status "$url" 8)"
        code="${result%% *}"; ms="${result#* }"
        if nd_status_ok "$code"; then
            nd_write "  [$group] $(printf '%-12s' "$name") OK    HTTP ${code}  ${ms}ms  $url"
        else
            nd_write "  [$group] $(printf '%-12s' "$name") FAIL  HTTP ${code}  ${ms}ms  $url"
        fi
    done

    nd_section "4. 出口 IP"
    for row in \
        "太平洋|国内|https://whois.pconline.com.cn/ipJson.jsp?json=true|1" \
        "UpaiYun|国内|https://pubstatic.b0.upaiyun.com/?_upnode|0" \
        "IP.SB|国外|https://api.ip.sb/geoip|0" \
        "IPInfo|国外|https://ipinfo.io/json|0"; do
        name="${row%%|*}"
        row="${row#*|}"
        group="${row%%|*}"
        row="${row#*|}"
        url="${row%%|*}"
        gbk="${row#*|}"
        result="$(nd_fetch_ip_provider "$name" "$url" "$gbk" || true)"
        nd_write "  [$group] ${result//$'\t'/  }"
    done

    nd_section "5. 路由器健康检查"
    hc="$(nd_api_get /api/v1/health/check 10)"
    [ -n "$hc" ] && printf '%s\n' "$hc" > "$ND_RUN_DIR/health_check.json"
    if [ -n "$hc" ]; then
        nd_show_router_status "$hc" "$(cat "$ND_RUN_DIR/cf_config.json" 2>/dev/null || true)" || true
    else
        nd_write "  /health/check 请求失败"
    fi

    nd_section "6. 路由器侧探测 (/overview/probes)"
    op="$(nd_api_get /api/v1/overview/probes 20)"
    if [ -n "$op" ]; then
        if command -v jq >/dev/null 2>&1; then
            printf '%s' "$op" | jq '.data // .' > "$ND_RUN_DIR/overview_probes.json" 2>/dev/null || printf '%s\n' "$op" > "$ND_RUN_DIR/overview_probes.json"
            ok_count="$(printf '%s' "$op" | jq '[.data.ip_checks[]?, .data.access_checks[]?] | map(select(.ok == true)) | length' 2>/dev/null || printf '0')"
            fail_count="$(printf '%s' "$op" | jq '[.data.ip_checks[]?, .data.access_checks[]?] | map(select(.ok == false)) | length' 2>/dev/null || printf '0')"
            nd_write "  路由器侧探测: ok=${ok_count:-0} fail=${fail_count:-0}"
        else
            printf '%s\n' "$op" > "$ND_RUN_DIR/overview_probes.json"
            ok_count="$(printf '%s' "$op" | awk '{ n += gsub(/"ok"[[:space:]]*:[[:space:]]*true/, "&") } END { print n + 0 }')"
            fail_count="$(printf '%s' "$op" | awk '{ n += gsub(/"ok"[[:space:]]*:[[:space:]]*false/, "&") } END { print n + 0 }')"
            nd_write "  路由器侧探测: ok=${ok_count:-0} fail=${fail_count:-0}"
        fi
    else
        nd_write "  /overview/probes 请求失败"
    fi

    svc="$(nd_api_get '/api/v1/service-log?lines=5000' 15)"
    req="$(nd_api_get '/api/v1/logs?limit=2000' 15)"
    [ -n "$svc" ] && printf '%s\n' "$svc" > "$ND_RUN_DIR/router_svc.log"
    [ -n "$req" ] && printf '%s\n' "$req" > "$ND_RUN_DIR/router_req.log"

    nd_section "本轮配对日志"
    for f in client.log router_svc.log router_req.log cf_config.json active_source.json subscriptions.json mihomo_config.yaml overview_probes.json health_check.json; do
        if [ -f "$ND_RUN_DIR/$f" ]; then
            sz="$(du -k "$ND_RUN_DIR/$f" 2>/dev/null | awk '{print $1}')"
            nd_write "  [x] $(printf '%-22s' "$f") ${sz:-0} KB"
        else
            nd_write "  [ ] $(printf '%-22s' "$f") (未生成)"
        fi
    done
    nd_write "探测完成，耗时 $(( $(date +%s) - start_ts ))s"
}

nd_manage_logs() {
    local total_kb threshold_kb reply d sz
    [ -d "$NETDIAG_LOG_DIR" ] || return 0
    total_kb="$(du -sk "$NETDIAG_LOG_DIR" 2>/dev/null | awk '{print $1}')"
    total_kb="${total_kb:-0}"
    threshold_kb=5120
    nd_section "本地诊断报告管理"
    nd_write "本地诊断报告总大小: ${total_kb} KB"
    [ "$total_kb" -le "$threshold_kb" ] && { nd_write "未超过 5MB 阈值，无需清理"; return 0; }
    if [ "$YES" -eq 1 ]; then
        reply="y"
    else
        printf '[clashforgectl] 是否删除最早的 run_* 报告直至低于 5MB？[y/N] '
        read -r reply
    fi
    case "$reply" in
        y|Y|yes|YES) ;;
        *) nd_write "保留所有记录"; return 0 ;;
    esac
    while [ "$total_kb" -gt "$threshold_kb" ]; do
        d="$(find "$NETDIAG_LOG_DIR" -maxdepth 1 -type d -name 'run_*' | sort | head -1)"
        [ -n "$d" ] || break
        [ "$d" = "$ND_RUN_DIR" ] && break
        sz="$(du -sk "$d" 2>/dev/null | awk '{print $1}')"
        rm -rf "$d"
        total_kb="$(( total_kb - ${sz:-0} ))"
        nd_write "已删除 $(basename "$d")"
    done
}

nd_monitor_loop() {
    local mon_log start elapsed ping_router ping_wan dns_ip http code ms internet was_lost=0 loss_start=0 loss_count=0 now dur fake
    mon_log="$ND_RUN_DIR/monitor.log"
    ND_LOG_FILE="$mon_log"
    nd_write ""
    nd_write "进入持续监控模式（Ctrl+C 停止）"
    start="$(date +%s)"
    while true; do
        now="$(date +%s)"
        elapsed="$((now - start))"
        nd_ping "$ROUTER" && ping_router="OK" || ping_router="FAIL"
        nd_ping 8.8.8.8 && ping_wan="OK" || ping_wan="FAIL"
        dns_ip="$(nd_dns_resolve google.com)"
        result="$(nd_http_status 'http://connectivitycheck.gstatic.com/generate_204' 4)"
        code="${result%% *}"; ms="${result#* }"
        if [ "$ping_wan" = "OK" ] && nd_status_ok "$code"; then internet=1; else internet=0; fi
        if [ "$internet" -eq 0 ] && [ "$was_lost" -eq 0 ]; then
            loss_start="$now"; was_lost=1; loss_count="$((loss_count + 1))"
            nd_write "[#${loss_count}] 断网 +${elapsed}s"
        elif [ "$internet" -eq 1 ] && [ "$was_lost" -eq 1 ]; then
            dur="$((now - loss_start))"; was_lost=0
            nd_write "[#${loss_count}] 恢复 断了 ${dur}s，总 +${elapsed}s"
        fi
        fake=""
        case "$dns_ip" in 198.18.*|198.19.*) fake="(fake-ip)" ;; esac
        nd_write "+${elapsed}s  rtr=${ping_router}  wan=${ping_wan}  dns=$([ -n "$dns_ip" ] && printf OK || printf FAIL)${fake}  http=$([ "$internet" -eq 1 ] && printf OK || printf FAIL)  ${ms}ms"
        sleep 2
    done
}

cmd_netdiag_client() {
    local stamp hc pre_cfg mihomo_before reply started=0
    nd_have_http_client || die "netdiag requires curl or wget."
    command -v ping >/dev/null 2>&1 || die "netdiag requires ping."

    stamp="$(date +%Y%m%d_%H%M%S)"
    ND_RUN_DIR="${NETDIAG_LOG_DIR%/}/run_${stamp}"
    mkdir -p "$ND_RUN_DIR"
    ND_LOG_FILE="$ND_RUN_DIR/client.log"

    printf '\n'
    nd_write "╔══════════════════════════════════════════════════════════════════════╗"
    nd_write "║      ClashForge 网络诊断脚本 (macOS/Linux 客户端)                  ║"
    nd_write "║      Router : ${ROUTER}:${NETDIAG_API_PORT}"
    nd_write "║      LogDir : ${ND_RUN_DIR}"
    nd_write "╚══════════════════════════════════════════════════════════════════════╝"
    nd_write ""

    nd_write "正在连接路由器 ${ROUTER}:${NETDIAG_API_PORT}..."
    if ! nd_ping "$ROUTER"; then
        nd_write "无法 Ping 通路由器 $ROUTER，请检查网络连接后重试"
        exit 1
    fi
    nd_write "路由器 $ROUTER 可达"

    nd_prescan_router_logs

    nd_section "路由器当前状态"
    hc="$(nd_api_get /api/v1/health/check 10)"
    pre_cfg="$(nd_api_get /api/v1/config 10)"
    if [ -n "$hc" ]; then
        if nd_show_router_status "$hc" "$pre_cfg"; then
            mihomo_before=1
        else
            mihomo_before=0
        fi
    else
        nd_write "/health/check 请求失败"
        mihomo_before=0
    fi
    if [ "$mihomo_before" -eq 1 ]; then
        nd_ensure_transparent_takeover "当前核心已运行"
    fi

    if [ "$mihomo_before" -eq 0 ]; then
        nd_write ""
        nd_write "mihomo 当前未运行。"
        if [ "$YES" -eq 1 ]; then
            reply="1"
        else
            printf '[clashforgectl] [1] 启动 mihomo 后诊断  [2] 不启动直接诊断  选择 [1/2]: '
            read -r reply
        fi
        if [ "$reply" = "1" ]; then
            if nd_start_mihomo; then
                started=1
                sleep 3
            else
                nd_write "mihomo 启动失败，继续执行诊断..."
            fi
        else
            nd_write "跳过启动，继续执行诊断..."
        fi
    fi

    nd_probe_suite

    if [ "$started" -eq 1 ]; then
        nd_write ""
        nd_write "诊断完成。脚本本次启动了 mihomo。"
        if [ "$YES" -eq 1 ]; then
            reply="1"
        else
            printf '[clashforgectl] [1] 还原(停止 mihomo)  [2] 保持运行  选择 [1/2]: '
            read -r reply
        fi
        if [ "$reply" = "1" ]; then
            nd_write "-> POST /api/v1/core/stop"
            nd_api_post /api/v1/core/stop >/dev/null
            nd_write "mihomo 已停止"
        else
            nd_write "mihomo 保持运行"
        fi
    fi

    nd_section "路由器日志清理"
    if [ -f "$ND_RUN_DIR/router_svc.log" ] && [ -f "$ND_RUN_DIR/router_req.log" ]; then
        nd_write "已确认路由器服务/请求日志副本已落盘本地，清理路由器侧日志缓冲..."
        nd_clear_router_logs
        nd_write "已清理"
    else
        nd_write "未能确认本地副本完整，跳过本次清理"
    fi

    nd_manage_logs
    nd_write ""
    nd_write "完整日志目录: $ND_RUN_DIR"

    if [ "$NETDIAG_MONITOR" -eq 1 ]; then
        nd_monitor_loop
    fi
}

sync_geodata_to_router() {
    if [ "$DRY_RUN" -eq 1 ]; then
        warn "Skipping GeoData preload because --dry-run is set"
        return 0
    fi

    local remote_dir="/etc/metaclash"
    local tmpdir

    # Check which files are already present on the router
    local remote_state=""
    declare -A need_upload
    need_upload["country.mmdb"]=1
    need_upload["GeoIP.dat"]=1
    need_upload["GeoSite.dat"]=1

    if remote_state="$(ssh "${SSH_OPTS[@]}" "$TARGET" \
        '[ -s /etc/metaclash/country.mmdb ] && echo mmdb=1   || echo mmdb=0
         [ -s /etc/metaclash/GeoIP.dat    ] && echo GeoIP=1  || echo GeoIP=0
         [ -s /etc/metaclash/GeoSite.dat  ] && echo GeoSite=1|| echo GeoSite=0' 2>/dev/null)"; then
        while IFS='=' read -r key value; do
            case "$key" in
                mmdb)    [ "$value" = "1" ] && need_upload["country.mmdb"]=0 ;;
                GeoIP)   [ "$value" = "1" ] && need_upload["GeoIP.dat"]=0    ;;
                GeoSite) [ "$value" = "1" ] && need_upload["GeoSite.dat"]=0  ;;
            esac
        done <<< "$remote_state"
    else
        warn "Unable to check existing GeoData on router, falling back to local preload"
    fi

    if [ "${need_upload[country.mmdb]}" -eq 0 ] && \
       [ "${need_upload[GeoIP.dat]}"    -eq 0 ] && \
       [ "${need_upload[GeoSite.dat]}"  -eq 0 ]; then
        ok "All GeoData files already exist on router, skipping preload"
        return 0
    fi

    tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/clashforge-geodata.XXXXXX")" || {
        warn "GeoData preload skipped: cannot create local temp directory"
        return 0
    }

    log "── GeoData: preloading missing files only"

    # Download each missing file (primary: GitHub releases; fallback: jsdmirror CDN)
    declare -A local_ok
    local_ok["country.mmdb"]=0
    local_ok["GeoIP.dat"]=0
    local_ok["GeoSite.dat"]=0

    if [ "${need_upload[country.mmdb]}" -eq 1 ]; then
        if download_with_fallback "country.mmdb" "$tmpdir/country.mmdb" \
            "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/country.mmdb" \
            "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@release/country.mmdb"; then
            local_ok["country.mmdb"]=1
        fi
    else
        ok "country.mmdb already exists on router, skip download/upload"
    fi

    if [ "${need_upload[GeoIP.dat]}" -eq 1 ]; then
        if download_with_fallback "GeoIP.dat" "$tmpdir/GeoIP.dat" \
            "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip.dat" \
            "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@release/geoip.dat"; then
            local_ok["GeoIP.dat"]=1
        fi
    else
        ok "GeoIP.dat already exists on router, skip download/upload"
    fi

    if [ "${need_upload[GeoSite.dat]}" -eq 1 ]; then
        if download_with_fallback "GeoSite.dat" "$tmpdir/GeoSite.dat" \
            "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geosite.dat" \
            "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@release/geosite.dat"; then
            local_ok["GeoSite.dat"]=1
        fi
    else
        ok "GeoSite.dat already exists on router, skip download/upload"
    fi

    local any_local=0
    for f in "country.mmdb" "GeoIP.dat" "GeoSite.dat"; do
        [ "${local_ok[$f]}" -eq 1 ] && any_local=1
    done

    if [ "$any_local" -eq 0 ]; then
        warn "GeoData preload skipped: no GeoData files could be downloaded locally"
        rm -rf "$tmpdir"
        return 0
    fi

    if ! ssh "${SSH_OPTS[@]}" "$TARGET" "mkdir -p $remote_dir"; then
        warn "GeoData preload skipped: cannot create $remote_dir on router"
        rm -rf "$tmpdir"
        return 0
    fi

    local uploaded_files=""
    for f in "country.mmdb" "GeoIP.dat" "GeoSite.dat"; do
        if [ "${local_ok[$f]}" -eq 1 ] && [ -s "$tmpdir/$f" ]; then
            if scp "${SCP_OPTS[@]}" "$tmpdir/$f" "${TARGET}:${remote_dir}/$f"; then
                ok "$f uploaded to ${remote_dir}/$f"
                uploaded_files="$uploaded_files $remote_dir/$f"
            else
                warn "Failed to upload $f to router"
            fi
        fi
    done

    if [ -n "$uploaded_files" ]; then
        # shellcheck disable=SC2086
        ssh "${SSH_OPTS[@]}" "$TARGET" "chmod 644$uploaded_files 2>/dev/null || true" \
            >/dev/null 2>&1 || true
    fi

    rm -rf "$tmpdir"
}

# ── locate clashforgectl.sh ───────────────────────────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SH_SCRIPT="$SCRIPT_DIR/clashforgectl.sh"

if [ ! -f "$SH_SCRIPT" ]; then
    # Try workspace root scripts/ directory (when called from repo root)
    SH_SCRIPT="$(dirname "$SCRIPT_DIR")/scripts/clashforgectl.sh"
fi

if [ ! -f "$SH_SCRIPT" ]; then
    SH_SCRIPT=""
fi

# ── defaults ──────────────────────────────────────────────────────────────────
ACTION=""
ROUTER=""
SSH_USER="root"
SSH_PORT="22"
IDENTITY=""

VERSION="latest"
MIRROR=""
BASE_URL=""
PURGE=0
REMOTE_DOWNLOAD=0
LOCAL_IPK_PATH=""

SKIP=""    # for deploy: comma-separated steps to skip (ui, go)
REPO_ROOT=""  # for deploy: auto-detected from script location

START=0
KEEP_CONFIG=0
PURGE_ALL=0

FETCH=0
REMOTE_OUTPUT="/tmp/cf-diag.txt"
LOCAL_PATH=""
REDACT=0

KILL_OPENCLASH=0

NETDIAG_API_PORT=7777
NETDIAG_LOG_DIR="./diag-logs"
NETDIAG_MONITOR=0

YES=0
DRY_RUN=0

# ── parse arguments ───────────────────────────────────────────────────────────
# First positional arg that is not a flag is the ACTION.
while [ $# -gt 0 ]; do
    case "$1" in
        status|stop|reset|upgrade|deploy|check|compat|uninstall|diag|openclash|flush-dns|netdiag|help)
            ACTION="$1"; shift ;;
        --router)     ROUTER="$2";      shift 2 ;;
        --router=*)   ROUTER="${1#*=}"; shift ;;
        --user)       SSH_USER="$2";    shift 2 ;;
        --user=*)     SSH_USER="${1#*=}"; shift ;;
        --port)       SSH_PORT="$2";    shift 2 ;;
        --port=*)     SSH_PORT="${1#*=}"; shift ;;
        --identity|-i) IDENTITY="$2";  shift 2 ;;
        --identity=*) IDENTITY="${1#*=}"; shift ;;
        # upgrade options
        --version)    VERSION="$2";     shift 2 ;;
        --version=*)  VERSION="${1#*=}"; shift ;;
        --mirror)     MIRROR="$2";      shift 2 ;;
        --mirror=*)   MIRROR="${1#*=}"; shift ;;
        --base-url)   BASE_URL="$2";    shift 2 ;;
        --base-url=*) BASE_URL="${1#*=}"; shift ;;
        --purge)         PURGE=1;           shift ;;
        --remote-download) REMOTE_DOWNLOAD=1; shift ;;
        --local-ipk)       LOCAL_IPK_PATH="$2"; shift 2 ;;
        --local-ipk=*)     LOCAL_IPK_PATH="${1#*=}"; shift ;;
        # deploy options
        --skip)       SKIP="$2";        shift 2 ;;
        --skip=*)     SKIP="${1#*=}";   shift ;;
        --repo-root)  REPO_ROOT="$2";   shift 2 ;;
        --repo-root=*) REPO_ROOT="${1#*=}"; shift ;;
        # reset options
        --start)      START=1;          shift ;;
        # uninstall options
        --keep-config) KEEP_CONFIG=1;   shift ;;
        --purge-all)   PURGE_ALL=1;     shift ;;
        # diag options
        --fetch)      FETCH=1;          shift ;;
        --output)     REMOTE_OUTPUT="$2"; shift 2 ;;
        --output=*)   REMOTE_OUTPUT="${1#*=}"; shift ;;
        --local-path) LOCAL_PATH="$2";  shift 2 ;;
        --local-path=*) LOCAL_PATH="${1#*=}"; shift ;;
        --redact)     REDACT=1;         shift ;;
        # openclash options
        --kill)       KILL_OPENCLASH=1; shift ;;
        # netdiag options
        --api-port)   NETDIAG_API_PORT="$2"; shift 2 ;;
        --api-port=*) NETDIAG_API_PORT="${1#*=}"; shift ;;
        --log-dir)    NETDIAG_LOG_DIR="$2"; shift 2 ;;
        --log-dir=*)  NETDIAG_LOG_DIR="${1#*=}"; shift ;;
        --monitor)    NETDIAG_MONITOR=1; shift ;;
        # common options
        --yes|-y)     YES=1;            shift ;;
        --dry-run)    DRY_RUN=1;        shift ;;
        --help|-h)    ACTION="help";    shift ;;
        *)
            die "Unknown argument: $1. Run with --help for usage."
            ;;
    esac
done

# ── help ──────────────────────────────────────────────────────────────────────
show_help() {
    cat <<'EOF'
clashforgectl — ClashForge Remote Control Script (macOS / Linux)

USAGE
    ./scripts/clashforgectl --router <host> <subcommand> [options]

SUBCOMMANDS
    status      Show current ClashForge state (read-only)
    stop        Stop ClashForge and exit takeover mode
    reset       Reset to first-install state (keeps installed package)
    upgrade     Install latest or a specific version
    deploy      Build locally, package as IPK, upload and install on router
    uninstall   Completely remove ClashForge from the router
    compat      Pre-install compatibility check (arch, memory, kernel, ports)
    diag        Collect a full diagnostic report
    openclash   Scan OpenClash processes/services; optionally kill them
    flush-dns   Flush dnsmasq DNS cache (and Mihomo fake-ip cache if core is running)
    netdiag     Run client-side network diagnostics via the ClashForge HTTP API
    help        Show this help

CONNECTION OPTIONS
    --router <host>      Router IP or hostname (required)
    --user <name>        SSH user (default: root)
    --port <port>        SSH port (default: 22)
    --identity <path>    Path to SSH private key

DEPLOY OPTIONS
    --skip <steps>       Comma-separated build steps to skip: ui, go
    --repo-root <path>   Repo root directory (default: auto-detect via go.mod)
    --purge              Full cleanup before install

UPGRADE OPTIONS
    --version <tag>      Version to install (default: latest)
    --mirror <url>       Force a GitHub proxy mirror for local download
    --base-url <url>     Custom release base URL for local download
    --purge              Full cleanup before install
    --remote-download    Legacy: have the router download the IPK itself
    --local-ipk <path>   Use a pre-downloaded IPK file; skips arch detect, version resolve, and download

RESET OPTIONS
    --start              Start ClashForge after reset

UNINSTALL OPTIONS
    --keep-config        Preserve /etc/metaclash after removal
    --purge-all          Delete EVERYTHING: config, keys, Cloudflare tokens, GeoData, binaries.
                         Cannot be combined with --keep-config.
                         Use this to fully reset the router to a clean state.

DIAG OPTIONS
    --fetch              Download report to local machine after collection
    --output <path>      Remote output path (default: /tmp/cf-diag.txt)
    --local-path <path>  Local path for fetched report (default: cf-diag_<router>_<timestamp>.txt)
    --redact             Best-effort masking of sensitive values

OPENCLASH OPTIONS
    --kill               Stop OpenClash service and kill detected OpenClash processes

NETDIAG OPTIONS
    --api-port <port>    ClashForge API port (default: 7777)
    --log-dir <path>     Local directory for diagnostic runs (default: ./diag-logs)
    --monitor            Continue monitoring after the one-shot probe suite

COMMON OPTIONS
    --yes                Skip confirmation prompts
    --dry-run            Print planned actions without making changes
    --help               Show this help

EXAMPLES
    ./scripts/clashforgectl --router 192.168.1.1 status
    ./scripts/clashforgectl --router 192.168.1.1 stop
    ./scripts/clashforgectl --router 192.168.1.1 reset --start
    ./scripts/clashforgectl --router 192.168.1.1 upgrade --version latest
    ./scripts/clashforgectl --router 192.168.1.1 upgrade --purge
    ./scripts/clashforgectl --router 192.168.1.1 upgrade --local-ipk /tmp/clashforge_0.1.0-beta.3_aarch64_generic.ipk
    ./scripts/clashforgectl --router 192.168.1.1 deploy
    ./scripts/clashforgectl --router 192.168.1.1 deploy --skip ui
    ./scripts/clashforgectl --router 192.168.1.1 deploy --purge
    ./scripts/clashforgectl --router 192.168.1.1 check
    ./scripts/clashforgectl --router 192.168.1.1 compat
    ./scripts/clashforgectl --router 192.168.1.1 uninstall --keep-config
    ./scripts/clashforgectl --router 192.168.1.1 uninstall --purge-all
    ./scripts/clashforgectl --router 192.168.1.1 diag --fetch --redact
    ./scripts/clashforgectl --router 192.168.1.1 openclash
    ./scripts/clashforgectl --router 192.168.1.1 openclash --kill
    ./scripts/clashforgectl --router 192.168.1.1 flush-dns
    ./scripts/clashforgectl --router 192.168.20.1 netdiag
    ./scripts/clashforgectl --router 192.168.20.1 netdiag --monitor
EOF
}

if [ "$ACTION" = "help" ]; then
    show_help
    exit 0
fi

# ── validate required args ────────────────────────────────────────────────────
[ -z "$ACTION" ] && { show_help; echo; die "--router and a subcommand are required."; }
[ -z "$ROUTER" ] && die "--router is required."

if [ "$ACTION" = "netdiag" ]; then
    cmd_netdiag_client
    exit 0
fi

[ -n "$SH_SCRIPT" ] || die "clashforgectl.sh not found. Expected: $SCRIPT_DIR/clashforgectl.sh"

# ── validate tools ────────────────────────────────────────────────────────────
for tool in ssh scp; do
    command -v "$tool" >/dev/null 2>&1 || die "$tool not found. Install OpenSSH (e.g. 'brew install openssh' or 'apt install openssh-client')."
done

# ── build SSH/SCP base arg arrays ─────────────────────────────────────────────
TARGET="${SSH_USER}@${ROUTER}"
SSH_OPTS=(-p "$SSH_PORT" -o StrictHostKeyChecking=no -o ConnectTimeout=15)
SCP_OPTS=(-P "$SSH_PORT" -o StrictHostKeyChecking=no -o ConnectTimeout=15)

if [ -n "$IDENTITY" ]; then
    SSH_OPTS+=(-i "$IDENTITY")
    SCP_OPTS+=(-i "$IDENTITY")
fi

REMOTE_SCRIPT="/tmp/clashforgectl.sh"

log "Router  : $TARGET  (port $SSH_PORT)"
log "Script  : $SH_SCRIPT"
log "Action  : $ACTION"

# ══════════════════════════════════════════════════════════════════════════════
# DEPLOY — local build + package + push to router
# ══════════════════════════════════════════════════════════════════════════════
if [ "$ACTION" = "deploy" ]; then
    # Auto-detect repo root: look for go.mod walking up from script dir
    if [ -z "$REPO_ROOT" ]; then
        REPO_ROOT="$SCRIPT_DIR"
        [ -f "$REPO_ROOT/go.mod" ] || REPO_ROOT="$(dirname "$SCRIPT_DIR")"
        [ -f "$REPO_ROOT/go.mod" ] || die "Cannot auto-detect repo root (no go.mod). Pass --repo-root."
    fi
    log "Repo root: $REPO_ROOT"
    log ""

    # ── 1. Bump patch version ─────────────────────────────────────────────────
    log "── Step 1: Bumping version"
    CONTROL_FILE="$REPO_ROOT/ipk/CONTROL/control"
    [ -f "$CONTROL_FILE" ] || die "control file not found: $CONTROL_FILE"
    OLD_VER="$(grep -m1 '^Version:' "$CONTROL_FILE" | awk '{print $2}')"
    [ -n "$OLD_VER" ] || die "Cannot parse version from $CONTROL_FILE"
    VER_PREFIX="${OLD_VER%.*}"
    VER_PATCH="${OLD_VER##*.}"
    NEW_VER="${VER_PREFIX}.$((VER_PATCH + 1))"
    # Use awk for in-place replacement (BusyBox-safe is not needed here — running on host)
    sed -i.bak "s/^Version: .*/Version: $NEW_VER/" "$CONTROL_FILE" && rm -f "${CONTROL_FILE}.bak"
    ok "Version $OLD_VER  →  $NEW_VER"
    IPK_NAME="clashforge_${NEW_VER}_x86_64.ipk"

    # ── 2. Build UI ───────────────────────────────────────────────────────────
    case "$SKIP" in *ui*)
        warn "Skipping UI build (--skip contains 'ui')" ;;
    *)
        log "── Step 2: Building React UI"
        (cd "$REPO_ROOT/ui" && VITE_APP_VERSION="$NEW_VER" npm run build) \
            || die "npm run build failed"
        UI_DIST="$REPO_ROOT/internal/api/ui_dist"
        rm -rf "$UI_DIST"/*
        cp -r "$REPO_ROOT/ui/dist/." "$UI_DIST/"
        ok "UI build complete"
        ;;
    esac

    # ── 3. Cross-compile Go ───────────────────────────────────────────────────
    case "$SKIP" in *go*)
        warn "Skipping Go build (--skip contains 'go')" ;;
    *)
        log "── Step 3: Cross-compiling Go (linux/amd64)"
        GOOS=linux GOARCH=amd64 CGO_ENABLED=0 \
            go build -trimpath -ldflags='-s -w' \
               -o "$REPO_ROOT/ipk/usr/bin/clashforge" \
               "$REPO_ROOT/cmd/clashforge" \
            || die "go build failed"
        ok "Binary written to ipk/usr/bin/clashforge"
        ;;
    esac

    # ── 4. Sync openwrt/files helpers → ipk/ ─────────────────────────────────
    log "── Step 4: Syncing openwrt/files helpers → ipk/"
    # Remove deprecated helper that was replaced by clashforgectl diag.
    rm -f "$REPO_ROOT/ipk/usr/bin/clashforge-diag"
    _sync() {
        src="$REPO_ROOT/$1"; dst="$REPO_ROOT/$2"
        if [ -f "$src" ]; then
            mkdir -p "$(dirname "$dst")"
            cp -f "$src" "$dst"
            ok "$(basename "$src")"
        else
            warn "Not found (skipped): $1"
        fi
    }
    _sync "openwrt/files/etc/init.d/metaclash"                              "ipk/etc/init.d/clashforge"
    _sync "openwrt/files/usr/share/luci/menu.d/luci-app-clashforge.json"    "ipk/usr/share/luci/menu.d/luci-app-clashforge.json"
    _sync "openwrt/files/www/luci-static/resources/view/clashforge/main.js" "ipk/www/luci-static/resources/view/clashforge/main.js"
    _sync "openwrt/files/usr/share/rpcd/acl.d/luci-app-clashforge.json"     "ipk/usr/share/rpcd/acl.d/luci-app-clashforge.json"
    _sync "openwrt/files/etc/metaclash/postinst.sh"                         "ipk/CONTROL/postinst"
    _sync "openwrt/files/etc/metaclash/prerm.sh"                            "ipk/CONTROL/prerm"
    _sync "openwrt/files/etc/metaclash/postrm.sh"                           "ipk/CONTROL/postrm"

    # ── 4.5. Pre-seed GeoData into IPK staging (best-effort, mirrors CI) ────────
    log "── Step 4.5: Pre-seeding GeoData into ipk/usr/share/metaclash/"
    mkdir -p "$REPO_ROOT/ipk/usr/share/metaclash"
    _geodata_seeded=0
    _gd_tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/clashforge-geodata.XXXXXX" 2>/dev/null)" || _gd_tmpdir=""
    if [ -n "$_gd_tmpdir" ]; then
        _seed_file() {
            local name="$1" dest="$2/usr/share/metaclash/$3"; shift 3
            [ -s "$dest" ] && { ok "$name already in staging, skip download"; return 0; }
            download_with_fallback "$name" "$_gd_tmpdir/$name" "$@" || return 1
            cp "$_gd_tmpdir/$name" "$dest" && ok "$name staged → ipk/usr/share/metaclash/"
        }
        _seed_file country.mmdb "$REPO_ROOT" country.mmdb \
            "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/country.mmdb" \
            "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@release/country.mmdb" \
            && _geodata_seeded=$((_geodata_seeded + 1)) || true
        _seed_file GeoIP.dat "$REPO_ROOT" GeoIP.dat \
            "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geoip.dat" \
            "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@release/geoip.dat" \
            && _geodata_seeded=$((_geodata_seeded + 1)) || true
        _seed_file GeoSite.dat "$REPO_ROOT" GeoSite.dat \
            "https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/geosite.dat" \
            "https://cdn.jsdmirror.com/gh/MetaCubeX/meta-rules-dat@release/geosite.dat" \
            && _geodata_seeded=$((_geodata_seeded + 1)) || true
        rm -rf "$_gd_tmpdir"
    fi
    if [ "$_geodata_seeded" -eq 3 ]; then
        ok "All 3 GeoData files bundled into IPK staging"
    else
        warn "GeoData pre-seed partial ($_geodata_seeded/3 files) — sync_geodata_to_router will fill gaps after install"
    fi

    # ── 5. Build IPK ─────────────────────────────────────────────────────────
    log "── Step 5: Building IPK ($IPK_NAME)"
    BUILD_SCRIPT="$REPO_ROOT/scripts/build_ipk.py"
    [ -f "$BUILD_SCRIPT" ] || die "build_ipk.py not found: $BUILD_SCRIPT"
    (cd "$REPO_ROOT" && PKG_NAME="$IPK_NAME" python3 "$BUILD_SCRIPT") \
        || die "build_ipk.py failed"
    LOCAL_IPK="$REPO_ROOT/$IPK_NAME"
    ok "IPK ready: $LOCAL_IPK"

    # ── 6. Upload IPK ─────────────────────────────────────────────────────────
    REMOTE_IPK="/tmp/cf_deploy.ipk"
    log "── Step 6: Uploading $IPK_NAME → ${TARGET}:${REMOTE_IPK}"
    scp "${SCP_OPTS[@]}" "$LOCAL_IPK" "${TARGET}:${REMOTE_IPK}" \
        || die "scp upload of IPK failed"
    ok "IPK uploaded"

    # ── 7. Upload clashforgectl.sh ────────────────────────────────────────────
    log "── Step 7: Uploading clashforgectl.sh → ${TARGET}:${REMOTE_SCRIPT}"
    scp "${SCP_OPTS[@]}" "$SH_SCRIPT" "${TARGET}:${REMOTE_SCRIPT}" \
        || die "scp upload of clashforgectl.sh failed"
    ok "clashforgectl.sh uploaded"

    # ── 8. Install via clashforgectl upgrade --local-ipk ─────────────────────
    PURGE_FLAG=""
    [ "$PURGE" -eq 1 ] && PURGE_FLAG=" --purge"
    REMOTE_INSTALL="sh $REMOTE_SCRIPT upgrade --local-ipk $REMOTE_IPK$PURGE_FLAG"
    log "── Step 8: Installing on router"
    log "Remote  : $REMOTE_INSTALL"
    log ""
    ssh "${SSH_OPTS[@]}" "$TARGET" "$REMOTE_INSTALL" \
        || die "Remote install failed"

    sync_geodata_to_router

    log ""
    ok "Deploy complete: $NEW_VER  →  http://${ROUTER}:7777"
    exit 0
fi


# ══════════════════════════════════════════════════════════════════════════════
# UPGRADE — download IPK locally, push to router, install via --local-ipk
#
# Default path: the local machine downloads the IPK and SCPs it to the router.
# This avoids the "chicken-and-egg" problem where ClashForge stopping breaks the
# router's internet access before it can download its own replacement.
# Use --remote-download to revert to the old behaviour (router downloads itself).
# ══════════════════════════════════════════════════════════════════════════════
if [ "$ACTION" = "upgrade" ] && [ "$REMOTE_DOWNLOAD" -eq 0 ]; then

    CLEANUP_LOCAL_IPK=0   # set to 1 only when we create a temp download

    if [ -n "$LOCAL_IPK_PATH" ]; then
        # ── User-supplied local IPK — skip arch detect, version resolve, download ─
        [ -f "$LOCAL_IPK_PATH" ] || die "Local IPK not found: $LOCAL_IPK_PATH"
        [ -s "$LOCAL_IPK_PATH" ] || die "Local IPK is empty: $LOCAL_IPK_PATH"
        IPK_NAME="$(basename "$LOCAL_IPK_PATH")"
        LOCAL_IPK="$LOCAL_IPK_PATH"
        ok "Local IPK   : $LOCAL_IPK_PATH ($(wc -c < "$LOCAL_IPK_PATH" | tr -d ' ') bytes)"
    else
        # ── 1. Detect router architecture ─────────────────────────────────────
        log "── Step 1: Detecting router architecture..."
        ROUTER_MACHINE="$(ssh "${SSH_OPTS[@]}" "$TARGET" 'uname -m')"

        case "$ROUTER_MACHINE" in
            x86_64|amd64)
                IPK_ARCH="x86_64" ;;
            aarch64|arm64)
                CPU_PART="$(ssh "${SSH_OPTS[@]}" "$TARGET" \
                    "grep -m1 'CPU part' /proc/cpuinfo 2>/dev/null | awk '{print tolower(\$NF)}'")"
                if [ "$CPU_PART" = "0xd03" ]; then
                    IPK_ARCH="aarch64_cortex-a53"
                else
                    IPK_ARCH="aarch64_generic"
                fi ;;
            *)
                die "Unsupported router architecture: $ROUTER_MACHINE (supported: x86_64, aarch64)" ;;
        esac
        ok "Router arch : $ROUTER_MACHINE → $IPK_ARCH"

        # ── 2. Resolve version ─────────────────────────────────────────────────
        TAG="$VERSION"
        if [ "$TAG" = "latest" ]; then
            log "── Step 2: Resolving latest release version..."
            _api="https://api.github.com/repos/wujun4code/clashforge/releases?per_page=50"
            _json="$(curl -fsSL --connect-timeout 15 --max-time 20 \
                        -H "Accept: application/vnd.github+json" \
                        "$_api" 2>/dev/null || true)"
            TAG="$(printf '%s' "$_json" | awk -F'"tag_name":"' '
                NF>1{
                  for (i=2; i<=NF; i++) {
                    split($i, a, "\"")
                    t=a[1]
                    if (t ~ /^v[0-9]+\.[0-9]+\.[0-9]+-beta\.[0-9]+$/) {
                      s=t
                      sub(/^v/, "", s)
                      sub(/-beta\./, ".", s)
                      n=split(s, p, ".")
                      key=sprintf("%09d.%09d.%09d.%09d", p[1], p[2], p[3], p[4])
                      if (key > best_key) {
                        best_key=key
                        best_tag=t
                      }
                    }
                  }
                }
                END{
                  if (best_tag != "") print best_tag
                }
              ')"
            if [ -z "$TAG" ]; then
                TAG="$(printf '%s' "$_json" | grep -o '"tag_name":"[^"]*"' | head -1 | cut -d'"' -f4)"
            fi
            [ -n "$TAG" ] || die "Failed to resolve latest version from GitHub API."
        fi
        PKG_VER="${TAG#v}"
        IPK_NAME="clashforge_${PKG_VER}_${IPK_ARCH}.ipk"
        ok "Version     : $TAG"
        ok "Package     : $IPK_NAME"

        # ── 3. Download IPK to local machine ──────────────────────────────────
        log "── Step 3: Downloading IPK locally..."
        LOCAL_IPK="$(mktemp /tmp/clashforge_XXXXXX).ipk"
        GH_URL="https://github.com/wujun4code/clashforge/releases/download/$TAG/$IPK_NAME"
        GH_PROXIES="https://ghproxy.com https://mirror.ghproxy.com https://ghfast.top https://github.moeyy.xyz"
        DOWNLOADED=0

        _dl() { curl -fsSL --connect-timeout 15 --max-time 300 -o "$LOCAL_IPK" "$1" 2>/dev/null && [ -s "$LOCAL_IPK" ]; }

        if [ -n "$BASE_URL" ]; then
            _url="${BASE_URL%/}/releases/$TAG/$IPK_NAME"
            log "Downloading from custom base URL: $BASE_URL"
            _dl "$_url" && DOWNLOADED=1 \
                || die "Download failed from base URL: $_url"
        elif [ -n "$MIRROR" ]; then
            _url="${MIRROR%/}/$GH_URL"
            log "Downloading via mirror: $MIRROR"
            _dl "$_url" && DOWNLOADED=1 \
                || die "Download failed from mirror: $MIRROR"
        else
            log "Downloading from GitHub..."
            if _dl "$GH_URL"; then
                DOWNLOADED=1
                ok "Downloaded from GitHub"
            else
                warn "Direct GitHub download failed, trying mirrors..."
                rm -f "$LOCAL_IPK"
                for _proxy in $GH_PROXIES; do
                    log "Trying mirror: $_proxy"
                    if _dl "$_proxy/$GH_URL"; then
                        DOWNLOADED=1
                        ok "Downloaded via $_proxy"
                        break
                    fi
                    rm -f "$LOCAL_IPK"
                done
            fi
        fi

        [ "$DOWNLOADED" -eq 1 ] \
            || die "Failed to download IPK from all sources.\nTry: --mirror https://ghproxy.com  or  --base-url <your-cdn>"
        ok "Local IPK   : $LOCAL_IPK ($(wc -c < "$LOCAL_IPK" | tr -d ' ') bytes)"
        CLEANUP_LOCAL_IPK=1
    fi

    # ── 4. Upload clashforgectl.sh ─────────────────────────────────────────────
    log "── Step 4: Uploading clashforgectl.sh → ${TARGET}:${REMOTE_SCRIPT}"
    scp "${SCP_OPTS[@]}" "$SH_SCRIPT" "${TARGET}:${REMOTE_SCRIPT}" \
        || die "scp upload of clashforgectl.sh failed"
    ok "clashforgectl.sh uploaded"

    # ── 5. Push IPK to router ──────────────────────────────────────────────────
    REMOTE_IPK="/tmp/$IPK_NAME"
    log "── Step 5: Pushing $IPK_NAME → ${TARGET}:${REMOTE_IPK}"
    scp "${SCP_OPTS[@]}" "$LOCAL_IPK" "${TARGET}:${REMOTE_IPK}" \
        || die "scp upload of IPK failed"
    ok "IPK pushed to router"
    [ "$CLEANUP_LOCAL_IPK" -eq 1 ] && rm -f "$LOCAL_IPK"

    # ── 6. Install on router via --local-ipk (no download needed on router) ──
    PURGE_FLAG="";  [ "$PURGE"   -eq 1 ] && PURGE_FLAG=" --purge"
    YES_FLAG="";    [ "$YES"     -eq 1 ] && YES_FLAG=" --yes"
    DRYRUN_FLAG=""; [ "$DRY_RUN" -eq 1 ] && DRYRUN_FLAG=" --dry-run"
    REMOTE_CMD="sh $REMOTE_SCRIPT upgrade --local-ipk $REMOTE_IPK$PURGE_FLAG$YES_FLAG$DRYRUN_FLAG"
    log "── Step 6: Installing on router"
    log "Remote  : $REMOTE_CMD"
    log ""
    ssh "${SSH_OPTS[@]}" "$TARGET" "$REMOTE_CMD" \
        || die "Remote install failed"

    sync_geodata_to_router

    log ""
    ok "Upgrade complete: $TAG  →  http://${ROUTER}:7777"
    exit 0
fi


# ── upload clashforgectl.sh to router ─────────────────────────────────────────
log "Uploading clashforgectl.sh to router..."
scp "${SCP_OPTS[@]}" "$SH_SCRIPT" "${TARGET}:${REMOTE_SCRIPT}" \
    || die "scp upload failed. Check router SSH access and disk space."
ok "Upload complete."

# ── build remote command ──────────────────────────────────────────────────────
REMOTE_CMD="sh $REMOTE_SCRIPT $ACTION"

case "$ACTION" in
    upgrade)
        [ "$VERSION" != "latest" ] && REMOTE_CMD="$REMOTE_CMD --version $(sh_quote "$VERSION")"
        [ -n "$MIRROR"   ]         && REMOTE_CMD="$REMOTE_CMD --mirror $(sh_quote "$MIRROR")"
        [ -n "$BASE_URL" ]         && REMOTE_CMD="$REMOTE_CMD --base-url $(sh_quote "$BASE_URL")"
        [ "$PURGE" -eq 1 ]         && REMOTE_CMD="$REMOTE_CMD --purge"
        ;;
    reset)
        [ "$START" -eq 1 ] && REMOTE_CMD="$REMOTE_CMD --start"
        ;;
    uninstall)
        [ "$KEEP_CONFIG" -eq 1 ] && REMOTE_CMD="$REMOTE_CMD --keep-config"
        [ "${PURGE_ALL:-0}" -eq 1 ] && REMOTE_CMD="$REMOTE_CMD --purge-all"
        ;;
    diag)
        REMOTE_CMD="$REMOTE_CMD --output $(sh_quote "$REMOTE_OUTPUT")"
        [ "$REDACT" -eq 1 ] && REMOTE_CMD="$REMOTE_CMD --redact"
        # Print to stdout only when not fetching
        [ "$FETCH" -eq 0 ] && REMOTE_CMD="$REMOTE_CMD --stdout"
        ;;
    openclash)
        [ "$KILL_OPENCLASH" -eq 1 ] && REMOTE_CMD="$REMOTE_CMD --kill"
        ;;
esac

[ "$YES"     -eq 1 ] && REMOTE_CMD="$REMOTE_CMD --yes"
[ "$DRY_RUN" -eq 1 ] && REMOTE_CMD="$REMOTE_CMD --dry-run"

log "Remote  : $REMOTE_CMD"
log ""

# ── execute on router ─────────────────────────────────────────────────────────
ssh "${SSH_OPTS[@]}" "$TARGET" "$REMOTE_CMD" \
    || die "Remote command failed."

# ── diag: fetch report to local machine ───────────────────────────────────────
if [ "$ACTION" = "diag" ] && [ "$FETCH" -eq 1 ]; then
    if [ -z "$LOCAL_PATH" ]; then
        TIMESTAMP="$(date +%Y%m%d_%H%M%S)"
        LOCAL_PATH="cf-diag_${ROUTER}_${TIMESTAMP}.txt"
    fi

    log ""
    log "Fetching diagnostic report from router..."
    if [ "$REDACT" -eq 1 ]; then
        warn "Fetching report with redaction applied on router side."
    else
        warn "Report is UNREDACTED — handle with care (may contain subscription URLs, tokens)."
    fi

    scp "${SCP_OPTS[@]}" "${TARGET}:${REMOTE_OUTPUT}" "$LOCAL_PATH" \
        || die "scp fetch failed. Remote path: $REMOTE_OUTPUT"

    # Resolve absolute local path for display
    ABS_LOCAL="$(cd "$(dirname "$LOCAL_PATH")" && pwd)/$(basename "$LOCAL_PATH")"

    ok ""
    ok "Diagnostic report fetched:"
    ok "  Remote : ${REMOTE_OUTPUT}"
    ok "  Local  : ${ABS_LOCAL}"
fi

ok ""
ok "Done."
